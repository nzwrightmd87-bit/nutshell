- selected_plan = local_assigns.fetch(:selected_plan, nil)

.form-section.membership-paywall
  %h2.membership-paywall__title= t('auth.sign_up.membership_gate_title')
  %p.membership-paywall__lead= t('auth.sign_up.membership_gate_preamble')

  .membership-paywall__plans
    - { monthly: t('auth.sign_up.monthly_plan_name'), yearly: t('auth.sign_up.yearly_plan_name') }.each do |plan, label|
      - plan_classes = ['membership-paywall__plan']
      - plan_classes << 'membership-paywall__plan--selected' if selected_plan == plan

      %section{ class: plan_classes }
        %p.membership-paywall__plan-name= label
        %p.membership-paywall__price
          %span.membership-paywall__price-amount= number_to_currency(paid_membership_plan_amount_cents(plan) / 100.0, precision: 0)
          %span.membership-paywall__interval= t("auth.sign_up.#{plan}_plan_interval")

        - if plan == :yearly
          %p.membership-paywall__savings= t('auth.sign_up.yearly_plan_savings')
        - else
          %p.membership-paywall__savings= t('auth.sign_up.monthly_plan_note')

        = link_to t('auth.sign_up.square_checkout'), checkout_billing_path(plan: plan), class: 'button button-secondary membership-paywall__cta'

  %p.membership-paywall__hint= t('auth.sign_up.continue_after_payment')
