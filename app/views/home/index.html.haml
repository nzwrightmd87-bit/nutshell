- if @render_landing_page
  - content_for :header_tags do
    = render partial: 'shared/og', locals: { description: 'Social media without surveillance advertising.' }

  = render 'shared/landing_page'
- else
  - content_for :header_tags do
    - unless request.path == '/'
      %meta{ name: 'robots', content: 'noindex' }/

    = render partial: 'shared/og'

  = render 'shared/web_app'
